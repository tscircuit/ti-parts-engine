{
  "name": "@tscircuit/ti-parts-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "bun": "./index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./footprint-library": {
      "types": "./footprint-library.ts",
      "bun": "./footprint-library.ts",
      "import": "./dist/footprint-library.js",
      "default": "./dist/footprint-library.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts footprint-library.ts --format esm --dts --sourcemap",
    "prepare": "bun run build",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "verify:lm358-bridge": "bun run scripts/verify-lm358-bridge.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/bun": "^1.2.22",
    "react": "^19.1.1",
    "tscircuit": "^0.0.1790",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@tscircuit/props": "^0.0.538",
    "debug": "^4.4.3",
    "jszip": "^3.10.1",
    "kicad-component-converter": "^0.1.40",
    "s-expression": "^3.1.1",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
